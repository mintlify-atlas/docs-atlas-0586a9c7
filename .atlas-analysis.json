  "keyFeatures": [
    "Custom domain support for shortened links",
    "Self-hostable with zero configuration needed",
    "Multiple database backends: SQLite, PostgreSQL, MySQL/MariaDB",
    "Optional Redis cache for performance",
    "Private link statistics (browser, OS, country, referrer)",
    "Password-protected and expiring links",
    "Admin dashboard to manage users, links, and domains",
    "RESTful API with API key authentication",
    "OpenID Connect (OIDC) login support",
    "Customizable themes via CSS, images, and Handlebars views",
    "Rate limiting for API routes",
    "Browser extensions for Chrome and Firefox"
  ],
  "publicApiSurface": [
    "GET /api/v2/health",
    "GET /api/v2/links",
    "POST /api/v2/links",
    "PATCH /api/v2/links/:id",
    "DELETE /api/v2/links/:id",
    "GET /api/v2/links/:id/stats",
    "POST /api/v2/domains",
    "DELETE /api/v2/domains/:id",
    "GET /api/v2/users"
  ]
